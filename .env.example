# Get your key from https://console.anthropic.com
ANTHROPIC_API_KEY=your_key_here

# Path to your Chrome profile for Tesco (persistent login)
TESCO_PROFILE_PATH=/path/to/your/chrome-profile

# Must be false — Tesco blocks headless browsers
PLAYWRIGHT_HEADLESS=false

# Optional — defaults to https://www.tesco.com
# TESCO_BASE_URL=https://www.tesco.com
